```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.out
build/
dist/

# Dependencies
.venv/
venv/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/
```